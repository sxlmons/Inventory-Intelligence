<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.15.xsd">

    <changeSet id="create-vendorinventorylot-table" author="you">

        <createTable tableName="vendorinventorylot">
            <column name="lot_id" type="integer" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="vendorinventorylot_pkey"/>
            </column>

            <column name="vendor_id" type="integer">
                <constraints nullable="false"/>
            </column>

            <column name="product_id" type="integer"/>

            <column name="quantity_on_hand" type="integer" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>

            <column name="unit_of_measurement" type="varchar(3)" defaultValue="kg">
                <constraints nullable="false"/>
            </column>

            <column name="total_weight" type="double precision" defaultValueNumeric="0.00">
                <constraints nullable="false"/>
            </column>

            <column name="last_restocked_date" type="timestamp"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Foreign key: product -->
        <addForeignKeyConstraint
                baseTableName="vendorinventorylot"
                baseColumnNames="product_id"
                constraintName="vendorinventorylot_product_id_fkey"
                referencedTableName="product"
                referencedColumnNames="product_id"/>

        
        <addForeignKeyConstraint
                baseTableName="vendorinventorylot"
                baseColumnNames="vendor_id"
                constraintName="vendorinventorylot_vendor_id_fkey"
                referencedTableName="vendor"
                referencedColumnNames="vendor_id"/>
        <createIndex indexName="idx_vil_vendor" tableName="vendorinventorylot">
            <column name="vendor_id"/>
        </createIndex>

        <createIndex indexName="idx_vil_product" tableName="vendorinventorylot">
            <column name="product_id"/>
        </createIndex>        

    </changeSet>

</databaseChangeLog>