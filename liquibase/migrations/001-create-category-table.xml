<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.15.xsd">

    <changeSet id="create-category-table" author="you">

        <createTable tableName="category">
            <column name="category_id" type="integer" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" primaryKeyName="category_pkey"/>
            </column>

            <column name="parent_category_id" type="integer"/>

            <column name="category_name" type="varchar(30)">
                <constraints nullable="false"/>
            </column>

            <column name="level_of_category" type="integer" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="timestamp"
                    defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Self-referencing foreign key (parent-child hierarchy) -->
        <addForeignKeyConstraint
                baseTableName="category"
                baseColumnNames="parent_category_id"
                constraintName="fk_category_parent"
                referencedTableName="category"
                referencedColumnNames="category_id"/>
        <addCheckConstraint
                tableName="category"
                constraintName="chk_no_self_parent"
                checkConstraint="category_id IS NULL OR category_id != parent_category_id"/>
        
        <createIndex indexName="idx_category_parent" tableName="category">
            <column name="parent_category_id"/>
        </createIndex>

    </changeSet>

</databaseChangeLog>